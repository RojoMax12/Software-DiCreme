APP_NAME=DiCreme
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tudominio.cl

# URL real del frontend en producción (usada para enlaces de recuperación de contraseña, etc.)
FRONTEND_URL=https://app.tudominio.cl

# --- Base de datos ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dicreme
DB_USERNAME=
DB_PASSWORD=

# --- JWT ---
# Genera un secreto largo y aleatorio, por ejemplo: openssl rand -base64 64
JWT_SECRET=
JWT_ALGO=HS256
# TTL de sesión normal en minutos
JWT_TTL=60
JWT_ISSUER=${APP_URL}
JWT_BLACKLIST_ENABLED=true

# --- Correo (para recuperación de contraseña, notificaciones) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@tudominio.cl"
MAIL_FROM_NAME="${APP_NAME}"

# --- CORS ---
# Dominio(s) exacto(s) del frontend permitido, separados por coma si hay más de uno.
CORS_ALLOWED_ORIGINS=https://app.tudominio.cl

LOG_CHANNEL=stack
LOG_LEVEL=warning